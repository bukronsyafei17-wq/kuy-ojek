<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kuy Ojek Indralaya</title>
    <link rel="manifest" href="manifest.json">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { max-width: 500px; margin: 0 auto; background-color: #f8fafc; min-height: 100vh; font-family: 'Inter', sans-serif; }
        .nav-active { color: #16a34a; font-weight: bold; border-top: 3px solid #16a34a; }
        .glass { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); }
        .order-card { transition: all 0.3s ease; }
        .order-card:active { transform: scale(0.98); }
    </style>
</head>
<body class="pb-24">

    <!-- Header & Logo (Click Logo 5x for Admin) -->
    <header class="bg-green-600 p-5 text-white shadow-lg sticky top-0 z-50 rounded-b-3xl">
        <div class="flex justify-between items-center">
            <div id="logoTrigger">
                <h1 class="text-2xl font-black italic tracking-tighter">KUY OJEK</h1>
                <p class="text-[10px] opacity-80 uppercase tracking-widest">Indralaya - Ogan Ilir</p>
            </div>
            <button id="logoutBtn" class="hidden h-10 w-10 bg-green-700 rounded-full flex items-center justify-center border border-green-400">
                <i class="fas fa-sign-out-alt"></i>
            </button>
        </div>
    </header>

    <!-- Halaman Login -->
    <div id="loginArea" class="p-6 mt-10">
        <div class="bg-white p-8 rounded-3xl shadow-2xl border border-gray-100">
            <div class="flex justify-center mb-6">
                <div class="h-20 w-20 bg-green-100 rounded-full flex items-center justify-center text-green-600">
                    <i class="fas fa-motorcycle text-4xl"></i>
                </div>
            </div>
            <h2 class="text-2xl font-bold text-center mb-2">Selamat Datang</h2>
            <p class="text-gray-400 text-center text-sm mb-8">Masuk untuk mulai perjalananmu di Indralaya</p>
            
            <input id="email" type="email" placeholder="Email" class="w-full bg-gray-50 border border-gray-200 p-4 mb-4 rounded-2xl outline-green-500 transition">
            <input id="pass" type="password" placeholder="Password" class="w-full bg-gray-50 border border-gray-200 p-4 mb-8 rounded-2xl outline-green-500 transition">
            
            <button onclick="auth()" class="w-full bg-green-600 text-white p-4 rounded-2xl font-bold text-lg shadow-xl hover:bg-green-700 active:scale-95 transition">
                MASUK / DAFTAR
            </button>
        </div>
    </div>

    <!-- Halaman Penumpang (User) -->
    <main id="userArea" class="hidden p-5">
        <div class="bg-white p-6 rounded-3xl shadow-md mb-8 border border-gray-100">
            <h3 class="font-bold text-lg mb-5 text-gray-800">Mau ke mana hari ini?</h3>
            <div class="space-y-4">
                <div class="relative">
                    <i class="fas fa-location-dot absolute left-4 top-4 text-green-500"></i>
                    <input id="pickup" type="text" placeholder="Lokasi Jemput..." class="w-full bg-gray-50 border-none p-4 pl-12 rounded-2xl text-sm focus:ring-2 focus:ring-green-500">
                </div>
                <div class="relative">
                    <i class="fas fa-flag absolute left-4 top-4 text-red-500"></i>
                    <input id="dest" type="text" placeholder="Tujuan ke mana?..." class="w-full bg-gray-50 border-none p-4 pl-12 rounded-2xl text-sm focus:ring-2 focus:ring-green-500">
                </div>
                <button onclick="cekHarga()" class="w-full bg-gray-900 text-white p-4 rounded-2xl font-bold">CEK TARIF</button>
            </div>
            
            <div id="hargaArea" class="hidden mt-6 p-6 bg-green-50 rounded-3xl border-2 border-green-200 text-center animate-bounce-in">
                <p class="text-xs text-green-600 uppercase font-bold tracking-widest mb-1">Total Biaya</p>
                <p id="totalHarga" class="text-4xl font-black text-green-800 mb-4"></p>
                <button onclick="orderNow()" class="w-full bg-green-600 text-white p-4 rounded-2xl font-bold shadow-lg">PESAN SEKARANG</button>
            </div>
        </div>

        <h4 class="font-bold text-gray-800 mb-4 ml-2">Aktivitas Saya</h4>
        <div id="userOrderList" class="space-y-4"></div>
    </main>

    <!-- Halaman Driver -->
    <main id="driverArea" class="hidden p-5">
        <div class="bg-blue-600 p-6 rounded-3xl text-white mb-8 shadow-blue-200 shadow-xl flex justify-between items-center">
            <div>
                <h2 class="text-2xl font-bold italic">DRIVER MODE</h2>
                <p class="text-xs opacity-80 uppercase">Siap terima orderan</p>
            </div>
            <i class="fas fa-satellite-dish text-3xl animate-pulse"></i>
        </div>
        <h4 class="font-bold text-gray-800 mb-4 ml-2">Orderan Tersedia</h4>
        <div id="driverOrderList" class="space-y-4"></div>
    </main>

    <!-- Halaman Admin (Keamanan PIN) -->
    <main id="adminArea" class="hidden p-5 animate-fade-in">
        <div class="bg-gray-900 p-6 rounded-3xl text-white mb-6 flex justify-between items-center shadow-2xl">
            <div>
                <h2 class="text-xl font-bold">PANEL ADMIN</h2>
                <p id="adminStats" class="text-[10px] text-yellow-400 font-mono"></p>
            </div>
            <button onclick="closeAdmin()" class="h-10 w-10 bg-gray-800 rounded-full"><i class="fas fa-times"></i></button>
        </div>
        <div id="adminOrderList" class="space-y-3"></div>
    </main>

    <!-- Navigasi Bawah -->
    <nav id="bottomNav" class="hidden fixed bottom-0 left-0 right-0 bg-white border-t border-gray-100 p-2 flex justify-around items-center glass max-w-[500px] mx-auto rounded-t-3xl shadow-2xl">
        <button onclick="switchTab('user')" id="navUser" class="flex flex-col items-center p-2 flex-1 transition nav-active">
            <i class="fas fa-home text-lg mb-1"></i>
            <span class="text-[10px] uppercase">Beranda</span>
        </button>
        <button onclick="switchTab('driver')" id="navDriver" class="flex flex-col items-center p-2 flex-1 transition text-gray-400">
            <i class="fas fa-motorcycle text-lg mb-1"></i>
            <span class="text-[10px] uppercase">Driver</span>
        </button>
        <button onclick="openAdmin()" id="navAdmin" class="hidden flex flex-col items-center p-2 flex-1 transition text-yellow-600">
            <i class="fas fa-user-shield text-lg mb-1"></i>
            <span class="text-[10px] uppercase font-bold">Admin</span>
        </button>
    </nav>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getAuth, signInWithEmailAndPassword, createUserWithEmailAndPassword, onAuthStateChanged, signOut } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";
        import { getFirestore, collection, addDoc, query, onSnapshot, orderBy, updateDoc, doc, deleteDoc, where } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyA0yKWJexlrzfxd186DiTR5sIn_rQFaT1M",
            projectId: "kuy-ojek-indralaya",
            appId: "1:802905342597:android:381c573eb70fbf034c1f81"
        };

        const app = initializeApp(firebaseConfig);
        const authObj = getAuth(app);
        const db = getFirestore(app);

        // --- SISTEM LOGIN ---
        window.auth = async () => {
            const email = document.getElementById('email').value;
            const pass = document.getElementById('pass').value;
            if(!email || !pass) return alert("Email & Password Kosong!");
            try { await signInWithEmailAndPassword(authObj, email, pass); }
            catch (e) { try { await createUserWithEmailAndPassword(authObj, email, pass); } catch (err) { alert(err.message); } }
        };
        document.getElementById('logoutBtn').onclick = () => signOut(authObj);

        onAuthStateChanged(authObj, user => {
            if (user) {
                document.getElementById('loginArea').classList.add('hidden');
                document.getElementById('bottomNav').classList.remove('hidden');
                document.getElementById('logoutBtn').classList.remove('hidden');
                switchTab('user');
            } else {
                document.getElementById('loginArea').classList.remove('hidden');
                document.getElementById('bottomNav').classList.add('hidden');
                document.getElementById('userArea').classList.add('hidden');
                document.getElementById('driverArea').classList.add('hidden');
                document.getElementById('adminArea').classList.add('hidden');
                document.getElementById('logoutBtn').classList.add('hidden');
            }
        });

        // --- NAVIGASI TAB ---
        window.switchTab = (tab) => {
            const sections = ['userArea', 'driverArea', 'adminArea'];
            const navs = ['navUser', 'navDriver', 'navAdmin'];
            
            sections.forEach(s => document.getElementById(s).classList.add('hidden'));
            navs.forEach(n => document.getElementById(n).classList.remove('nav-active', 'text-gray-400'));
            navs.forEach(n => document.getElementById(n).classList.add('text-gray-400'));

            document.getElementById(tab + 'Area').classList.remove('hidden');
            document.getElementById('nav' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('nav-active');
            document.getElementById('nav' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.remove('text-gray-400');

            if(tab === 'user') loadUserOrders();
            if(tab === 'driver') loadDriverOrders();
            if(tab === 'admin') loadAdminOrders();
        };

        // --- FITUR PENUMPANG ---
        let globalHarga = 0;
        window.cekHarga = () => {
            const dest = document.getElementById('dest').value;
            if(!dest) return alert("Isi tujuannya dulu!");
            globalHarga = 5000 + (dest.length * 400); // Simulasi
            document.getElementById('totalHarga').innerText = "Rp " + globalHarga.toLocaleString();
            document.getElementById('hargaArea').classList.remove('hidden');
        };

        window.orderNow = async () => {
            await addDoc(collection(db, "orders"), {
                user: authObj.currentUser.email,
                pickup: document.getElementById('pickup').value,
                dest: document.getElementById('dest').value,
                price: globalHarga, status: "WAITING", time: Date.now()
            });
            alert("Pesanan dikirim! Mohon tunggu driver.");
            document.getElementById('hargaArea').classList.add('hidden');
        };

        function loadUserOrders() {
            const q = query(collection(db, "orders"), where("user", "==", authObj.currentUser.email), orderBy("time", "desc"));
            onSnapshot(q, s => {
                let h = '';
                s.forEach(d => {
                    const data = d.data();
                    h += `<div class="bg-white p-5 rounded-3xl shadow-sm border border-gray-100 order-card">
                        <div class="flex justify-between mb-3">
                            <span class="text-[10px] bg-gray-100 px-2 py-1 rounded-full text-gray-500 font-mono">${new Date(data.time).toLocaleTimeString()}</span>
                            <span class="text-[10px] font-bold uppercase ${data.status=='WAITING'?'text-orange-500':'text-green-600'}">${data.status}</span>
                        </div>
                        <p class="text-sm"><b>Ke:</b> ${data.dest}</p>
                        <p class="text-lg font-black text-green-700">Rp ${data.price.toLocaleString()}</p>
                        ${data.status=='TAKEN' ? `<a href="https://wa.me/${data.driver_wa}" class="block mt-4 bg-green-500 text-white text-center p-4 rounded-2xl font-bold"><i class="fab fa-whatsapp mr-2"></i> HUBUNGI DRIVER</a>` : ''}
                    </div>`;
                });
                document.getElementById('userOrderList').innerHTML = h || '<p class="text-center text-gray-400 mt-10">Belum ada pesanan</p>';
            });
        }

        // --- FITUR DRIVER ---
        function loadDriverOrders() {
            const q = query(collection(db, "orders"), where("status", "==", "WAITING"), orderBy("time", "desc"));
            onSnapshot(q, s => {
                let h = '';
                s.forEach(d => {
                    const data = d.data();
                    h += `<div class="bg-white p-5 rounded-3xl shadow-md border-l-8 border-blue-500">
                        <p class="text-sm mb-1"><b>Jemput:</b> ${data.pickup}</p>
                        <p class="text-sm mb-4"><b>Tujuan:</b> ${data.dest}</p>
                        <div class="flex justify-between items-center">
                            <span class="text-xl font-black text-blue-700">Rp ${data.price.toLocaleString()}</span>
                            <button onclick="ambilOrder('${d.id}')" class="bg-blue-600 text-white px-6 py-2 rounded-xl font-bold">AMBIL</button>
                        </div>
                    </div>`;
                });
                document.getElementById('driverOrderList').innerHTML = h || '<p class="text-center text-gray-400 mt-10">Menunggu orderan baru...</p>';
            });
        }
        window.ambilOrder = async (id) => {
            const wa = prompt("Masukkan No WhatsApp Anda (Gunakan 62, Cth: 62812xxx):");
            if(wa) await updateDoc(doc(db, "orders", id), { status: "TAKEN", driver_wa: wa.replace(/\D/g,'') });
        };

        // --- KEAMANAN ADMIN (LOGO CLICK 5X) ---
        let clickCount = 0;
        document.getElementById('logoTrigger').onclick = () => {
            clickCount++;
            if(clickCount >= 5) {
                const pin = prompt("MASUKKAN PIN ADMIN:");
                if(pin === "1234") { // SILAKAN GANTI PIN ANDA DI SINI
                    document.getElementById('navAdmin').classList.remove('hidden');
                    alert("MODE ADMIN DIAKTIFKAN!");
                }
                clickCount = 0;
            }
        };

        window.openAdmin = () => switchTab('admin');
        window.closeAdmin = () => {
            document.getElementById('navAdmin').classList.add('hidden');
            switchTab('user');
        };

        function loadAdminOrders() {
            const q = query(collection(db, "orders"), orderBy("time", "desc"));
            onSnapshot(q, s => {
                let h = ''; let count = 0;
                s.forEach(d => {
                    count++;
                    const data = d.data();
                    h += `<div class="bg-white p-4 rounded-2xl shadow mb-3 border-l-4 ${data.status=='WAITING'?'border-orange-400':'border-green-500'}">
                        <div class="flex justify-between text-[10px] mb-2">
                            <b class="text-blue-600">${data.user}</b>
                            <button onclick="hapus('${d.id}')" class="text-red-500 underline">HAPUS</button>
                        </div>
                        <p class="text-xs">${data.pickup} -> ${data.dest}</p>
                        <p class="text-xs font-bold text-green-700 mt-1">Rp ${data.price.toLocaleString()} (${data.status})</p>
                    </div>`;
                });
                document.getElementById('adminOrderList').innerHTML = h;
                document.getElementById('adminStats').innerText = `TOTAL DATABASE: ${count} ORDERAN`;
            });
        }
        window.hapus = async (id) => { if(confirm("Hapus selamanya?")) await deleteDoc(doc(db, "orders", id)); };

    </script>
    <script>if ('serviceWorker' in navigator) { navigator.serviceWorker.register('sw.js'); }</script>
</body>
</html>
